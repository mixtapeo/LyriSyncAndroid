<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/onboardingOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:elevation="100dp"
    android:clickable="true"
    android:focusable="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Setup"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="1. Connect to Spotify"
                android:textColor="#1DB954"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap 'Allow' when the Spotify prompt appears."
                android:textColor="#A0A0A0" />

            <ImageView
                android:id="@+id/gifAuth"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:background="#1E1E1E"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="2. Enable Broadcast Status"
                android:textColor="#1DB954"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spotify Settings > Device Broadcast Status > ON"
                android:textColor="#A0A0A0" />

            <ImageView
                android:id="@+id/gifBroadcast"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:background="#1E1E1E"
                android:scaleType="centerInside" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1DB954"
            android:text="I'VE DONE BOTH"
            android:textColor="#000000"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnDontShow"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Don't show again"
            android:textColor="#A0A0A0" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>