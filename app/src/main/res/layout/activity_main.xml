<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="10"
    android:background="#121212">

    <!-- Info + Jisho Section -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lyricRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:background="#121212"
        android:clipToPadding="false"
        android:paddingTop="80dp"
        android:paddingBottom="80dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:background="#202124"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/songTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Song Title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#8AB4F8"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/artistNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist Name"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A3A3A"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jisho Details (Kanji Breakdown):"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/jishoDetailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Listening for Japanese lyrics..."
                android:textSize="16sp"
                android:textColor="#E0E0E0"
                android:lineSpacingExtra="4dp" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>